generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider  = "postgresql"
  // url       = env("DATABASE_URL")
}

// Role: ADMIN, STAFF
// TicketStatus: TODO, IN_PROGRESS, AWAITING_USER, RESOLVED, CLOSED
// Priority: P0 (Critical), P1 (High), P2 (Normal - default), P3 (Low)

model User {
  id           Int           @id @default(autoincrement())
  username     String        @unique
  email        String        @unique
  password     String
  name         String?
  role         String        @default("STAFF")
  isActive     Boolean       @default(true)
  tickets      Ticket[]      @relation("AssignedTickets")
  comments     Comment[]
  attachments  Attachment[]
  activityLogs ActivityLog[]
  assets       Asset[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model Ticket {
  id            Int          @id @default(autoincrement())
  title         String
  description   String
  status        String       @default("TODO")
  priority      String       @default("P2")
  requesterName String?
  assignedTo    User?        @relation("AssignedTickets", fields: [assignedToId], references: [id])
  assignedToId  Int?
  slaBreachAt   DateTime?
  dueDate       DateTime?
  timeSpent     Int          @default(0)
  folder        Folder?      @relation(fields: [folderId], references: [id])
  folderId      Int?
  asset         Asset?       @relation(fields: [assetId], references: [id])
  assetId       Int?
  tags          String[]
  tasks         Task[]
  checklists    ChecklistItem[]
  comments      Comment[]
  attachments   Attachment[]
  activityLogs  ActivityLog[]
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

model Comment {
  id         Int      @id @default(autoincrement())
  content    String
  ticket     Ticket   @relation(fields: [ticketId], references: [id])
  ticketId   Int
  author     User?    @relation(fields: [authorId], references: [id])
  authorId   Int?
  authorName String?
  createdAt  DateTime @default(now())
}

model Attachment {
  id        Int      @id @default(autoincrement())
  fileName  String
  filePath  String
  fileSize  Int
  mimeType  String
  ticket    Ticket   @relation(fields: [ticketId], references: [id])
  ticketId  Int
  uploadedBy User?    @relation(fields: [authorId], references: [id])
  authorId  Int?
  createdAt DateTime @default(now())
}

model ActivityLog {
  id        Int      @id @default(autoincrement())
  ticket    Ticket   @relation(fields: [ticketId], references: [id])
  ticketId  Int
  user      User?    @relation(fields: [userId], references: [id])
  userId    Int?
  action    String   // e.g., "STATUS_CHANGE", "ASSIGNMENT", "PRIORITY_CHANGE"
  field     String?  // e.g., "status"
  oldValue  String?
  newValue  String?
  createdAt DateTime @default(now())
}

model Task {
  id          Int      @id @default(autoincrement())
  title       String
  description String
  status      String   @default("TODO")
  ticket      Ticket   @relation(fields: [ticketId], references: [id])
  ticketId    Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SLAPolicy {
  id               Int      @id @default(autoincrement())
  name             String
  priority         String   @unique
  responseTimeMins Int
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Automation {
  id        Int      @id @default(autoincrement())
  name      String
  trigger   String
  condition String?
  action    String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ChecklistItem {
  id          Int      @id @default(autoincrement())
  title       String
  isCompleted Boolean  @default(false)
  ticket      Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  ticketId    Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model KanbanColumn {
  id        Int      @id @default(autoincrement())
  title     String   @unique
  order     Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Space {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  folders     Folder[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Folder {
  id          Int      @id @default(autoincrement())
  name        String
  space       Space    @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  spaceId     Int
  tickets     Ticket[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Asset {
  id           Int      @id @default(autoincrement())
  name         String
  type         String   // e.g., LAPTOP, DESKTOP, SERVER, SOFTWARE
  status       String   @default("ACTIVE") // e.g., ACTIVE, MAINTENANCE, RETIRED
  description  String?
  serialNumber String?  @unique
  manufacturer String?
  model        String?
  location     String?
  purchaseDate DateTime?
  warrantyExpiry DateTime?
  purchaseCost Decimal?
  specs        Json?    // For technical specs like RAM, CPU, License Keys
  assignedTo   User?    @relation(fields: [assignedToId], references: [id])
  assignedToId Int?
  tickets      Ticket[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
